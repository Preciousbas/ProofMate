{
  "name": "proofmate",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "mcp": "tsx mcp/server.ts",
    "db:generate": "drizzle-kit generate",
