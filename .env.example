# Required for EVM contract verification (Etherscan / BscScan / BaseScan family via API v2)
ETHERSCAN_API_KEY=

# Required for holder stats, supply metadata (EVM + Solana via Moralis)
MORALIS_API_KEY=

# Optional: Solscan Pro for richer Solana holder counts / verified listings
# Without it, ProofMate still uses Solana RPC + Moralis and links to Solscan
SOLSCAN_API_KEY=

# Optional: custom Solana RPC (defaults to public mainnet)
# SOLANA_RPC_URL=

# Optional: Blockscout Pro key for Robinhood Chain (and other Blockscout instances)
# Get one at https://dev.blockscout.com — key prefix proapi_
ROBINHOOD_API_KEY=
# BLOCKSCOUT_API_KEY=

# DexScreener is public — no key required

# Optional: polish trust memos with Groq (falls back to template if unset)
GROQ_API_KEY=

# Production ASP auth — gates /api/analyze|search|resolve|follow-up
# Generate a long random secret; never commit the real value
# PROOFMATE_API_KEY=

# Optional but recommended in production: shared rate limits across isolates
# Create a free Redis DB at https://upstash.com and paste REST credentials
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Public site URL for MCP clients (e.g. https://your-app.vercel.app)
# PROOFMATE_BASE_URL=
