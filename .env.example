# Required for EVM contract verification (Etherscan / BscScan / BaseScan family via API v2)
ETHERSCAN_API_KEY=

# Required for holder stats, supply metadata (EVM + Solana via Moralis)
MORALIS_API_KEY=

# Optional: Solscan Pro for richer Solana holder counts / verified listings
# Without it, ProofMate still uses Solana RPC + Moralis and links to Solscan
SOLSCAN_API_KEY=

# Optional: custom Solana RPC (defaults to public mainnet)
# SOLANA_RPC_URL=

# Optional: Blockscout Pro key for Robinhood Chain (and other Blockscout instances)
# Get one at https://dev.blockscout.com — key prefix proapi_
ROBINHOOD_API_KEY=
# BLOCKSCOUT_API_KEY=

# DexScreener is public — no key required

# Optional: polish trust memos with Groq (falls back to template if unset)
GROQ_API_KEY=
# Set to 1/true to skip Groq memo polish (faster analyzes; template copy only)
# PROOFMATE_SKIP_MEMO_POLISH=1
# Set to 0/false to disable open-ended Groq follow-ups (rules + fallback only)
# PROOFMATE_FOLLOW_UP_LLM=0

# Production ASP auth — optional owner/MCP bypass when x402 is on
# Generate a long random secret; never commit the real value
# PROOFMATE_API_KEY=

# --- OKX x402 (required for marketplace paid skill calls) ---
# From OKX Developer Portal. Unpaid skill routes return HTTP 402.
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=
# Wallet that receives the $0.01 per-call fee (X Layer)
# PAY_TO_ADDRESS=0x...
# Optional overrides:
# OKX_BASE_URL=https://www.okx.com
# X402_NETWORK=eip155:196
# X402_PRICE=$0.01

# Optional but recommended in production: shared rate limits across isolates
# Create a free Redis DB at https://upstash.com and paste REST credentials
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Public site URL for MCP clients (e.g. https://your-app.vercel.app)
# PROOFMATE_BASE_URL=

# --- Auth (Google + email/password) + Postgres chats ---
# Auth.js secret: openssl rand -base64 32
AUTH_SECRET=
# App origin (local: http://localhost:3000, prod: https://your-domain)
AUTH_URL=http://localhost:3000
# Google OAuth client — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
# Optional if you only use email/password
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Neon Postgres (Vercel Marketplace: vercel integration add neon)
DATABASE_URL=